    "t=int(input())\n",
    "\n",
    "for i in range(t):\n",
    "    number=int(input())\n",
    "    if number == 0:\n",
    "        print(0)\n",
    "        continue\n",
    "    while number>0:\n",
    "        print(number%10, end=\" \")\n",
    "        number=int(number/10)\n",
    "    print()\n",
